# Production environment template.
# Copy these names into your hosting provider (Vercel/Render/etc.).
# Do not commit real values.

DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Must match the live browser host (www). Apex ≠ www breaks Clerk session cookies.
NEXT_PUBLIC_APP_URL="https://www.yourdomain.com"
OPENAI_API_KEY="sk-..."

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/register"

STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

RESEND_API_KEY="re_..."
EMAIL_FROM="Faztino <noreply@yourdomain.com>"

HEALTH_CHECK_SECRET="replace-with-random-secret"
SECRET_ENCRYPTION_KEY="replace-with-stable-random-base64-32-byte-secret"

# Optional demo bot shown on the landing page.
NEXT_PUBLIC_DEMO_BOT_ID="demo_site_assistant"

# Optional NGN/Paystack billing. Leave unset if Stripe-only.
# PAYSTACK_SECRET_KEY=""
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
# PAYSTACK_STARTER_PLAN_CODE=""
# PAYSTACK_PRO_PLAN_CODE=""
