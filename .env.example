# Database — Neon (recommended): pooled URL for the app, direct URL for Prisma CLI (migrate / db push).
# From Neon Dashboard → Connect: copy the "pooled" string into DATABASE_URL and the "direct" into DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"
# Local Postgres (no Neon driver): set DIRECT_URL to the same value as DATABASE_URL and PRISMA_NEON=false
# PRISMA_NEON=false
# After schema changes: npm run db:push   (or prisma migrate dev in production)
# Stripe webhook idempotency uses table StripeWebhookEvent — run db:push after pulling updates.

# Dev only: allow training to crawl http://localhost / 127.0.0.1 (your bot’s Website URL). Do not set in production.
# ALLOW_LOCAL_TRAINING_URL=1

# OpenAI
OPENAI_API_KEY="sk-..."

# Public URL of this app (embed script + Stripe redirects)
# Production MUST be the canonical host you use in the browser, including www if you use www:
#   NEXT_PUBLIC_APP_URL="https://www.faztino.com"
# Apex and www do NOT share Clerk cookies — next.config redirects faztino.com → www.faztino.com.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev only: register /sw.js (service worker). Omit in dev to avoid SW caching surprises; production registers automatically.
# NEXT_PUBLIC_ENABLE_SW_IN_DEV=1

# If VERCEL_AUTOMATION_BYPASS_SECRET is not present (non-Vercel or older projects), set the same value as
# Vercel → Project → Deployment Protection → Protection Bypass for Automation, so generated embed snippets work.
# WIDGET_VERCEL_PROTECTION_BYPASS=

# Training crawl: on Vercel, skip downloading Playwright’s full browser (Chromium comes from @sparticuz/chromium).
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
# Optional path to Chrome/Chromium for local “rendered” training if `npx playwright install chromium` is not used.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
# Force static fetch-only training (no headless browser fallback).
# CRAWLER_DISABLE_RENDER=1

# Transactional email (Resend — https://resend.com), e.g. admin notifications or marketing.
# IMPORTANT: For production you MUST verify your own domain in Resend (Domains → Add Domain)
# and set EMAIL_FROM to an address on that domain. The shared sandbox sender
# `onboarding@resend.dev` only delivers to the Resend account owner — paying
# customers, lead notifications, and booking confirmations will silently drop
# if you leave the sandbox value in production.
RESEND_API_KEY=""
EMAIL_FROM="Your Brand <noreply@yourdomain.com>"

# Demo assistant on the marketing homepage (matches prisma/seed default id)
NEXT_PUBLIC_DEMO_BOT_ID="demo_site_assistant"

# Stripe — subscriptions (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=""
# Also accepted: STRIPE_API_KEY
# Monthly recurring price ids (price_…) — required on Vercel Production, not only in local .env
STRIPE_PRICE_STARTER=""
# Also: STRIPE_PRICE_STARTER_MONTHLY, STRIPE_PRICE_STARTER_YEARLY
STRIPE_PRICE_PRO=""
# Also: STRIPE_PRICE_PRO_MONTHLY, STRIPE_PRO_PRICE_ID, STRIPE_PRICE_ID, NEXT_PUBLIC_STRIPE_PRICE_PRO
# Webhook signing secret — subscribe endpoint to at least:
#   checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=""
# In Stripe: enable Customer portal (Settings → Billing → Customer portal) so "Manage billing" works

# Paystack — optional NGN billing. Leave unset to price and bill users in USD via Stripe.
# PAYSTACK_SECRET_KEY=""
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
# PAYSTACK_STARTER_PLAN_CODE=""
# PAYSTACK_PRO_PLAN_CODE=""

# Clerk — customer sign-in + admin (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Production (e.g. faztino): set NEXT_PUBLIC_APP_URL to the canonical site origin you use in the browser.
# NEXT_PUBLIC_APP_URL="https://www.faztino.com"
#
# Leave CLERK_FRONTEND_API_PROXY unset (default off). The app then calls your Clerk Frontend API
# directly (clerk.yourdomain.com from the publishable key). Do NOT enable the same-origin /__clerk
# proxy unless you configured it in Clerk Dashboard — otherwise you get code "host_invalid".
# CLERK_FRONTEND_API_PROXY=1
#
# Clerk Dashboard → Domains: add every origin users visit (https://www.faztino.com AND https://faztino.com
# if both work). Use localhost OR 127.0.0.1 consistently in dev, not mixed.
# Behind nginx/Caddy: forward X-Forwarded-Host and X-Forwarded-Proto
# (https://clerk.com/docs/guides/development/deployment/behind-a-proxy).
# Paths must match your app routes (used by middleware redirects)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/register"
# Must match the live browser host (www). Apex after_sign_in in Clerk Dashboard will
# mint cookies on the wrong host — override with these force/fallback URLs.
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="https://www.faztino.com/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="https://www.faztino.com/dashboard"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="https://www.faztino.com/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="https://www.faztino.com/dashboard"
# Admin panel: Clerk Dashboard → Users → [user] → Metadata → Public or Private → JSON:
#   { "role": "admin" }
# Optional escape hatch (comma-separated Clerk user ids, same instance as keys above):
# ADMIN_CLERK_USER_IDS="user_xxxxxxxxxxxxxxxxxxxxxxxx"
# Use production publishable/secret keys on Vercel (not pk_test_ / sk_test_).

# --- Production hardening (recommended) ---
# Upstash Redis — shared rate limits across serverless instances (https://upstash.com).
# Without this, rate limits are per-instance memory only (weaker under load).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# If set, /api/health DB check requires Authorization: Bearer <secret> or ?token=<secret>
HEALTH_CHECK_SECRET="replace-with-a-random-health-check-secret"

# REQUIRED in production. Authorises the scheduled job at /api/cron/prune-visitors,
# which deletes visitor analytics older than 90 days — the retention window promised
# in the privacy policy. Vercel Cron sends this as `Authorization: Bearer <secret>`.
# Without it the job refuses to run (an unauthenticated delete endpoint is worse than
# a missed prune), and the retention promise silently goes unkept.
CRON_SECRET="replace-with-a-random-cron-secret"

# REQUIRED in production. AES-256-GCM key used to encrypt webhook signing
# secrets at rest in the Webhook table. Generate with:
#   openssl rand -base64 32
# Rotating this key invalidates all stored encrypted secrets — set once and
# treat it like a database password.
SECRET_ENCRYPTION_KEY=""

# Sentry observability (https://sentry.io). Leave unset for zero overhead.
# When SENTRY_DSN is set, src/lib/logger.ts forwards .warn/.error to Sentry
# and src/instrumentation.ts captures unhandled server errors.
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE="0.05"

# Optional: comma-separated exact Origins allowed to call /api/chat and /api/leads.
# Leave empty for public embeds (any site can host the widget script).
# WIDGET_ALLOWED_ORIGINS="https://app.example.com"

# Calendar sync — OAuth credentials for Google and Microsoft calendars
# Google Calendar: https://console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client ID, add redirect URI: {NEXT_PUBLIC_APP_URL}/api/calendar/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Calendar: https://portal.azure.com → App registrations
# Create app, add redirect URI: {NEXT_PUBLIC_APP_URL}/api/calendar/microsoft/callback
# API permissions: Calendars.ReadWrite, offline_access
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Web Push Notifications — VAPID keys for sending push notifications to mobile/web
# Generate with: npx web-push generate-vapid-keys
# Required for mobile PWA notifications (new leads, appointments)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:your-email@yourdomain.com"
