# Database (PostgreSQL — e.g. Neon, Supabase, or local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# After schema changes: npm run db:push   (or prisma migrate dev in production)

# OpenAI
OPENAI_API_KEY="sk-..."

# Auth (generate: openssl rand -base64 32) — required in production
AUTH_SECRET=""
# Must match your deployed origin (https://yourdomain.com)
NEXTAUTH_URL="http://localhost:3000"

# Public URL of this app (embed script + Stripe redirects + auth email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Transactional email (Resend — https://resend.com). Required in production for signup verification & password reset.
# Outside production, if unset, new accounts are auto-verified and reset links are logged to the console.
RESEND_API_KEY=""
EMAIL_FROM="24/7concept <onboarding@resend.dev>"

# Demo assistant on the marketing homepage (matches prisma/seed default id)
NEXT_PUBLIC_DEMO_BOT_ID="demo_site_assistant"

# Stripe — Pro subscriptions (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=""
# Recurring price ID for the Pro plan (Products → Prices)
STRIPE_PRICE_PRO=""
# Webhook signing secret — subscribe endpoint to at least:
#   checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=""
# In Stripe: enable Customer portal (Settings → Billing → Customer portal) so "Manage billing" works

# Clerk (admin console only — https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# In Clerk Dashboard → Users → Public metadata, set { "role": "admin" } for ops accounts.

# --- Production hardening (recommended) ---
# Upstash Redis — shared rate limits across serverless instances (https://upstash.com)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# If set, /api/health DB check requires Authorization: Bearer <secret> or ?token=<secret>
HEALTH_CHECK_SECRET=""

# Optional: comma-separated exact Origins allowed to call /api/chat and /api/leads.
# Leave empty for public embeds (any site can host the widget script).
# WIDGET_ALLOWED_ORIGINS="https://app.example.com"
