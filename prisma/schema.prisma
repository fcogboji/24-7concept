generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String    @id @default(cuid())
  clerkId                String?   @unique
  email                  String    @unique
  passwordHash           String?
  name                   String?
  emailVerifiedAt        DateTime?
  plan                   String    @default("free")
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  subscriptionStatus     String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  bots                   Bot[]
  auditLogs              AuditLog[]
  authTokens             AuthToken[]
}

model AuthToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model StripeWebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  actorClerkId String?
  actorEmail   String?
  action       String
  resourceType String?
  resourceId   String?
  meta         Json?
  ip           String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([userId])
}

model Bot {
  id                String    @id @default(cuid())
  userId            String
  name              String
  websiteUrl        String?
  businessInfo      String?   @db.Text
  isDemo            Boolean   @default(false)
  trainingStartedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources           Source[]
  messages          Message[]
  leads             Lead[]

  @@index([userId])
}

model Lead {
  id        String   @id @default(cuid())
  botId     String
  email     String
  name      String?
  phone     String?
  sessionId String?
  pageUrl   String?
  status    String   @default("new")
  source    String   @default("widget")
  createdAt DateTime @default(now())
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@index([sessionId])
}

model Source {
  id        String   @id @default(cuid())
  botId     String
  content   String   @db.Text
  embedding Json
  createdAt DateTime @default(now())
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId])
}

model Message {
  id        String   @id @default(cuid())
  botId     String
  role      String
  content   String   @db.Text
  sessionId String?
  pageUrl   String?
  createdAt DateTime @default(now())
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@index([sessionId])
}
