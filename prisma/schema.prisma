generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String    @id @default(cuid())
  clerkId                String?   @unique
  email                  String    @unique
  name                   String?
  emailVerifiedAt        DateTime?
  plan                   String    @default("free")
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  subscriptionStatus     String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  bots                   Bot[]
  auditLogs              AuditLog[]
  webhooks               Webhook[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model Webhook {
  id        String   @id @default(cuid())
  userId    String
  url       String
  events    String
  active    Boolean  @default(true)
  label     String?
  secret    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model StripeWebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}

model PaystackWebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  actorClerkId String?
  actorEmail   String?
  action       String
  resourceType String?
  resourceId   String?
  meta         Json?
  ip           String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([userId])
}

model Bot {
  id                String    @id @default(cuid())
  userId            String
  name              String
  websiteUrl        String?
  avatarUrl         String?
  businessInfo      String?   @db.Text
  isDemo            Boolean   @default(false)
  trainingStartedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  // Restrict (not Cascade) so an accidental User row delete cannot wipe a
  // paying customer's bots and all their conversation/lead history. Account
  // deletion must explicitly purge bots first.
  user              User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  sources           Source[]
  messages          Message[]
  leads             Lead[]
  bookingConfig     BookingConfig?
  appointments      Appointment[]

  @@index([userId])
}

model Lead {
  id        String   @id @default(cuid())
  botId     String
  email     String
  name      String?
  phone     String?
  sessionId String?
  pageUrl   String?
  status    String   @default("new")
  source    String   @default("widget")
  createdAt DateTime @default(now())
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@index([botId, email])
  @@index([sessionId])
}

model Source {
  id        String   @id @default(cuid())
  botId     String
  content   String   @db.Text
  embedding Json
  createdAt DateTime @default(now())
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId])
}

model Message {
  id        String   @id @default(cuid())
  botId     String
  role      String
  content   String   @db.Text
  sessionId String?
  pageUrl   String?
  createdAt DateTime @default(now())
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@index([sessionId])
}

model BookingConfig {
  id              String        @id @default(cuid())
  botId           String        @unique
  enabled         Boolean       @default(false)
  timezone        String        @default("America/New_York")
  slotDurationMin Int           @default(30)
  bufferMin       Int           @default(0)
  maxAdvanceDays  Int           @default(30)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  bot             Bot           @relation(fields: [botId], references: [id], onDelete: Cascade)
  weeklyHours     WeeklyHours[]
  services        Service[]
  blockedDates    BlockedDate[]
}

model WeeklyHours {
  id              String        @id @default(cuid())
  bookingConfigId String
  dayOfWeek       Int
  startTime       String
  endTime         String
  bookingConfig   BookingConfig @relation(fields: [bookingConfigId], references: [id], onDelete: Cascade)

  @@unique([bookingConfigId, dayOfWeek, startTime])
  @@index([bookingConfigId])
}

model Service {
  id              String        @id @default(cuid())
  bookingConfigId String
  name            String
  durationMin     Int
  description     String?       @db.Text
  price           String?
  active          Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  bookingConfig   BookingConfig @relation(fields: [bookingConfigId], references: [id], onDelete: Cascade)
  appointments    Appointment[]

  @@index([bookingConfigId])
}

model BlockedDate {
  id              String        @id @default(cuid())
  bookingConfigId String
  date            DateTime      @db.Date
  reason          String?
  bookingConfig   BookingConfig @relation(fields: [bookingConfigId], references: [id], onDelete: Cascade)

  @@index([bookingConfigId])
}

model Appointment {
  id        String   @id @default(cuid())
  botId     String
  serviceId String?
  sessionId String?
  name      String
  email     String
  phone     String?
  startTime DateTime
  endTime   DateTime
  timezone  String   @default("UTC")
  status    String   @default("confirmed")
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([botId, startTime])
  @@index([botId, status])
  @@index([sessionId])
  @@index([email])
}
